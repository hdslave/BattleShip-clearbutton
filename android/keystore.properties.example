# keystore.properties — release signing configuration (LOCAL ONLY).
#
# This file is gitignored. Copy to keystore.properties and fill in the
# values; ./gradlew bundleRelease will then sign the AAB / APK with
# your release key. Without this file (and without the matching
# SSB64_RELEASE_* env vars), release builds fall back to the debug
# keystore — runnable locally, NOT distributable.
#
# To generate a keystore once:
#   keytool -genkey -v -keystore release.jks \
#           -alias ssb64-release -keyalg RSA -keysize 2048 -validity 10000

# Absolute path; resolved as-is (no ~ expansion).
storeFile=/absolute/path/to/release.jks
storePassword=keystore-password-here
keyAlias=ssb64-release
keyPassword=key-password-here
